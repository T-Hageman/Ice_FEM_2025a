{ 
    "Restart":{
        "Restartable": false,
        "Saveloc": "Results/Backup",
        "SaveFrequency": 1,
        "BackUps": 3
    },
    "Logs":{
        "InfoLevel": 2
    },
    "mesh":{
        "dim":2,
        "file":"TestCases/DynamicCrackBranching/MeshGen/quadratic_02mm.h5",
        "ipcount1D": 3
    },
    "properties":{
        "PhaseField":{
            "_Comment": "Properties for fracture phase-field: length scale l [m], interfacial energy Gc [J/m^2]",
            "DamFunction": "Quadratic",
            "DensityDamage": "None",
            "GravityDamage": "None",
            "Split": "SpecStrains",
            "ConsistentEnergy": false,
            "ConsistentDegradation": false,
            "DistributionFunction": "HO_Linear",
            "l": 0.5e-3,
            "k0": 1.0e-6,
            "Viscosity": 0.0
        },
        "Solid":{
            "_Comment": "Properties describing the metal: intact material density Density [kg/m^3]",
            "Density": 2450,
            "Young": 32.0e9,
            "Poisson": 0.2,
            "Gc": 3.0,
            "Rheology":{
                "Type": "LinearElastic",
                "_Type": "DamViscoElastic", 
                "PhiViscLim": 1.1,
                "A": 5.0e-24,
                "n": 3.0
            }
        },
        "TimeDiscretisation":{
            "Scheme": "Newmark",
            "beta": 0.5625,
            "gamma": 1.0 
        }
    },
    "Dofs":{
        "DofNames": ["ux","uy","phase","lMult_pf"],
        "DofStep":  [0,   0,   0,      0]
    },
    "nonlinSolver":{ 
        "max_it": 50,
        "max_outer_it": 1,
        "convCrit": [1.0e-9, 1.0e10, 1.0e-9],
        "tiny": [1.0e-6, 1.0e10, 1.0e-8],
        "linesearch": false,
        "linesearchLims": [0.25, 1],
        "LinSolver":{
            "_Comment": "MUMPS options: https://graal.ens-lyon.fr/MUMPS/doc/userguide_5.5.1.pdf",
            "_Type": "MUMPS",
            "_IOptionIdx": [14],
            "_IOptionVals": [5000],
            "_Comment2": "PARDISO options: https://pardiso-project.org/manual/manual.pdf  https://www.intel.com/content/www/us/en/develop/documentation/onemkl-developer-reference-c/top/sparse-solver-routines/onemkl-pardiso-parallel-direct-sparse-solver-iface/pardiso-iparm-parameter.html",
            "Type": "Pardiso",
            "IOptionIdx": [],
            "IOptionVals": []
        },
        "Initialization":{
            "Type": "DamageChallenge",
            "InteriorGroup": "internal",
            "Notch_x": [0, 50e-3],
            "Notch_y": [19.5e-3, 20.5e-3]
        }
    },
    "TimeSolver":{
        "t0": -10.0,
        "dt0": 1.0,
        "dt": 1e-6,
        "tmax": 100.0e-6,
        "outputN": 1
    },
    "Visualisation":{
        "Plots": ["ux","uy","PhaseField"],
        "ElementGroup_u": "internal",
        "ux":{
            "Type": "Surf_2D",
            "Dof": "ux",
            "ElementGroup": "internal",
            "Deformed": false,
            "DeformedScale": 10.0,
            "Frequency": "it"
        },
        "uy":{
            "Type": "Surf_2D",
            "Dof": "uy",
            "ElementGroup": "internal",
            "Deformed": false,
            "DeformedScale": 10.0,
            "Frequency": "it"
        },
        "PhaseField":{
            "Type": "Surf_2D",
            "Dof": "phase",
            "ElementGroup": "internal",
            "Deformed": false,
            "Frequency": "it"
        }
    },
    "Outputs":{
        "OutputMeshOnlyOnce": true,
        "SaveFolder":"Results",
        "ElementGroups": ["internal"],
        "internal":{
            "Nodes": ["ux","uy","phase"],
            "IP":["sxx","syy","szz","sxy"]
        }
    },
    "Models":{
        "Names":["PhaseField1","Boundary1","Boundary2"],
        "PhaseField1":{
            "Name": "Fracture/PhaseField",
            "ElementGroup_u": "internal",
            "ElementGroup_phase": "internal",
            "Material": "Solid",
            "ViscousStab": 0.0,
            "Irreversible": "AugmentedLagrangeMult",
            "Intertia": true,
            "Gravity": false,
            "LumpedPFCapacity": false,
            "LumpedDriving": false
        },
        "Boundary1":{
            "Name": "ExternalForce",   
            "ElementGroup":"top",      
            "dofs": ["uy"],            
            "Force": [1.0e6]      
        },
        "Boundary2":{
            "Name": "ExternalForce",   
            "ElementGroup":"bottom",      
            "dofs": ["uy"],            
            "Force": [-1.0e6]    
        },
        "_Boundary1":{
            "Name": "Constraints",
            "NodeGroup":"top",
            "dofs": ["uy"],
            "values": [1e-6]
        },
        "_Boundary2":{
            "Name": "Constraints",
            "NodeGroup":"bottom",
            "dofs": ["uy"],
            "values": [-1e-6]
        }
    }
}